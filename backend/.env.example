# ─── Django Core ───────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-min-50-chars-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.almerak.ae

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgres://almerak:password@localhost:5432/almerak_db

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Azure Storage (UAE North) ─────────────────────────────────
AZURE_ACCOUNT_NAME=almerakuae
AZURE_ACCOUNT_KEY=your-azure-storage-key
AZURE_CONTAINER=kyc-documents
AZURE_CUSTOM_DOMAIN=almerakuae.blob.core.windows.net

# ─── Email (SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-key
DEFAULT_FROM_EMAIL=noreply@almerak.ae
COMPLIANCE_ALERT_EMAIL=compliance@almerak.ae

# ─── SMS (Twilio) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_FROM_NUMBER=+971xxxxxxxx

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_STARTER_PRICE_ID=price_xxxx
STRIPE_PROFESSIONAL_PRICE_ID=price_xxxx

# ─── External Watchlists / Screening ───────────────────────────
OFAC_API_KEY=your-ofac-api-key
WORLD_CHECK_API_KEY=your-world-check-key
NEWS_API_KEY=your-newsapi-key

# ─── ComplyAdvantage (AML + Sanctions + PEP + Adverse Media) ───
# Sign up: https://complyadvantage.com
COMPLYADVANTAGE_API_KEY=

# ─── Sumsub (KYC · Emirates ID · Passport · Face Verification) ─
# Sign up: https://sumsub.com  → Dashboard → Settings → API Keys
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=
# The verification level name created in your Sumsub dashboard
SUMSUB_LEVEL_NAME=basic-kyc-level

# ─── SEON (Fraud Detection · Email · Phone · IP Risk) ──────────
# Sign up: https://seon.io → Admin → API Keys
SEON_API_KEY=

# ─── Sentry ────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/xxx

# ─── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.almerak.ae
